{
  "compilerOptions": {
    "esModuleInterop": true,
    "outDir": "./dist/",
    "strict": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "module": "NodeNext",
    "target": "es6",
    "jsx": "react",
    "allowJs": true,
    "moduleResolution": "nodenext",
    "rootDir": "src",
    "types": ["jest"],
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ],
}
